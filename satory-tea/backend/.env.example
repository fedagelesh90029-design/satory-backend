PORT=3000
JWT_SECRET=satory_secret_2026

# Секрет для x-admin-secret заголовка (загрузка файлов, корректировка бонусов)
ADMIN_SECRET=satory_admin_2026

# Логин/пароль администратора для панели управления
ADMIN_LOGIN=admin
ADMIN_PASSWORD=satory2026

# Секрет для HMAC-подписи QR-кодов
QR_SECRET=satory_qr_secret_2026

# SMS (sms.ru) — получить API ID на sms.ru/my/api
SMS_PROVIDER=smsru
SMS_API_KEY=
# Cron-расписание для автосинхронизации товаров (каждые 6 часов)
IIKO_SYNC_CRON=0 */6 * * *
# Cron-расписание для автосинхронизации бонусов (каждый час)
IIKO_BONUS_SYNC_CRON=0 * * * *

# ─── Яндекс.Диск (опционально) ───────────────────────────────────────────────
# OAuth-токен: https://oauth.yandex.ru → создать приложение → получить токен
YANDEX_TOKEN=

# Путь к папке на Яндекс.Диске с файлами товаров (напр. disk:/iiko/products)
YANDEX_PRODUCTS_FOLDER_ID=disk:/iiko/products

# Путь к папке на Яндекс.Диске с бонусными отчётами (напр. disk:/iiko/bonuses)
YANDEX_BONUSES_FOLDER_ID=disk:/iiko/bonuses

# Расписание синхронизации с Яндекс.Диском (по умолчанию каждый час)
SYNC_CRON_PRODUCTS=0 * * * *
SYNC_CRON_BONUSES=0 * * * *
