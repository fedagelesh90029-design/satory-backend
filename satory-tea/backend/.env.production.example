# 🚀 ПРОДАКШЕН настройки для Satori Tea
# Скопируйте этот файл в .env и заполните реальными данными

# Основные настройки
NODE_ENV=production
PORT=3000
APP_URL=https://satory-tea.ru  # ВАШ РЕАЛЬНЫЙ ДОМЕН с HTTPS

# JWT секрет для авторизации (сгенерируйте новый!)
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_64_СИМВОЛА_МИНИМУМ

# ЮKassa (Яндекс.Касса) - РЕАЛЬНЫЕ ДАННЫЕ
YOOKASSA_SHOP_ID=123456  # ID магазина из личного кабинета ЮKassa
YOOKASSA_SECRET_KEY=live_ABC123DEF456...  # Секретный ключ из ЮKassa

# СБП (Система быстрых платежей) - получить в банке
SBP_MERCHANT_ID=ваш_merchant_id_от_банка
SBP_SECRET_KEY=ваш_secret_key_от_банка
SBP_API_URL=https://securepay.tinkoff.ru/sbp/v1  # URL API банка

# SMS сервис для OTP (опционально)
SMS_API_KEY=ваш_ключ_sms_сервиса
SMS_SENDER=SatoriTea

# Push-уведомления Expo
EXPO_ACCESS_TOKEN=ваш_expo_access_token

# Яндекс.Диск для синхронизации (опционально)
YANDEX_TOKEN=ваш_yandex_disk_token
YANDEX_PRODUCTS_FOLDER_ID=папка_для_товаров
YANDEX_BONUSES_FOLDER_ID=папка_для_бонусов

# Настройки платежей
PAYMENT_TIMEOUT=900  # 15 минут на оплату
MIN_PAYMENT_AMOUNT=100  # Минимальная сумма 100 рублей

# Настройки бонусной системы
BONUS_RATE=0.01  # 1% кэшбек
BONUS_MIN_ORDER=500  # Минимальная сумма для начисления бонусов

# Настройки синхронизации (опционально)
SYNC_CRON_PRODUCTS=0 */2 * * *  # Каждые 2 часа
SYNC_CRON_BONUSES=0 */4 * * *   # Каждые 4 часа

# QR-коды для бонусов
QR_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_ДЛЯ_QR_КОДОВ