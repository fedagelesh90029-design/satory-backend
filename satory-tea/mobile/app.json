{
  "expo": {
    "name": "Satory",
    "slug": "satory-tea",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "satory",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.satory.tea"
    },
    "android": {
      "package": "com.satory.tea"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#0A0A0A"
    }
  }
}
