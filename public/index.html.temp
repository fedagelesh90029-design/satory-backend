<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SATORI — Чайный дом</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{ --bg:#0A0A0A; --card:#141414; --border:#222; --gold:#C9A84C; --gold-h:#E8C96A; --text:#FFFFFF; --muted:#888; --muted-l:#AAAAAA; }
html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}

/* ── NAV ── */
nav{ position:fixed;top:0;left:0;right:0;z-index:100;padding:20px 40px;display:flex;align-items:center;justify-content:space-between;transition:background .3s; }
nav.scrolled{background:rgba(10,10,10,.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border)}
.nav-logo{font-size:20px;font-weight:800;letter-spacing:4px;color:var(--gold);text-decoration:none}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{color:var(--muted-l);text-decoration:none;font-size:14px;letter-spacing:1px;transition:color .2s}
.nav-links a:hover{color:var(--gold)}
.nav-app{ padding:10px 22px;border-radius:20px;border:1px solid var(--gold);color:var(--gold);font-size:13px;font-weight:600;text-decoration:none; }

/* ── HERO ── */
.hero{ position:relative;height:100vh;min-height:600px;display:flex;align-items:center;justify-content:center;text-align:center;background:url('https://images.unsplash.com/photo-1564890369478-c89ca6d9cde9?w=1920&q=90&fit=crop') center/cover no-repeat; }
.hero::after{ content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.6) 0%,rgba(0,0,0,.75) 100%); }
.hero-content{position:relative;z-index:1;padding:0 24px}
.hero-icon{ width:80px;height:80px;border-radius:50%;background:rgba(0,0,0,0.4);border:2px solid rgba(201,168,76,0.5);display:inline-flex;align-items:center;justify-content:center;margin:0 auto 20px;overflow:hidden; }
.hero-icon img{width:70px;height:70px;object-fit:contain}
.hero h1{font-size:clamp(48px,8vw,96px);font-weight:800;letter-spacing:8px;margin-bottom:12px}
.hero p{font-size:18px;color:rgba(255,255,255,.75);letter-spacing:2px;margin-bottom:32px}
.hero-btn{ display:inline-block;padding:14px 36px;border-radius:40px;background:var(--gold);color:#0A0A0A;font-size:15px;font-weight:700;text-decoration:none; }

/* ── SECTIONS ── */
section{padding:100px 0}
.container{max-width:1100px;margin:0 auto;padding:0 40px}
.section-title{font-size:clamp(28px,4vw,42px);font-weight:700;margin-bottom:60px}

/* ── ABOUT ── */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.about-text h2{font-size:clamp(28px,4vw,42px);font-weight:700;margin-bottom:24px}
.about-text p{color:var(--muted-l);line-height:1.8;font-size:16px;margin-bottom:16px}
.about-img{border-radius:20px;overflow:hidden;aspect-ratio:4/3}
.about-img img{width:100%;height:100%;object-fit:cover}
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:60px}
.info-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px}
.info-card-icon{width:44px;height:44px;border-radius:50%;background:rgba(201,168,76,.15);display:flex;align-items:center;justify-content:center;margin-bottom:16px;font-size:20px;}
.info-card h3{font-size:16px;font-weight:700;margin-bottom:8px}
.info-card p{color:var(--muted-l);font-size:14px;line-height:1.6}

/* ── GALLERY ── */
.gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}
.gallery-item{border-radius:16px;overflow:hidden;background:var(--card);aspect-ratio:1/1}
.gallery-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s}
.gallery-item:hover img{transform:scale(1.05)}

/* ── REVIEWS ── */
.reviews-section{background:var(--card)}
.reviews-rating{display:flex;align-items:center;gap:16px;margin-bottom:48px;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);border-radius:16px;padding:24px 32px;width:fit-content;}
.reviews-rating-num{font-size:56px;font-weight:800;color:var(--gold);line-height:1}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.review-card{background:var(--bg);border:1px solid var(--border);border-radius:16px;padding:24px}
.review-stars{color:var(--gold);font-size:16px;margin-bottom:12px;letter-spacing:2px}
.review-text{color:var(--muted-l);font-size:14px;line-height:1.7;margin-bottom:16px}
.review-author{display:flex;align-items:center;gap:12px}
.review-avatar{width:40px;height:40px;border-radius:50%;background:rgba(201,168,76,.2);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:var(--gold)}

/* ── FOOTER ── */
footer{background:var(--bg);border-top:1px solid var(--border);padding:60px 0 40px;text-align:center;}
.footer-icon{width:32px;height:32px;border-radius:50%;border:1px solid var(--gold);display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px}
.footer-icon img{width:20px;height:20px;object-fit:contain}
.footer-logo{font-size:24px;font-weight:800;letter-spacing:6px;color:var(--gold);margin-bottom:8px}
.footer-links{display:flex;justify-content:center;gap:32px;margin:32px 0;flex-wrap:wrap}
.footer-links a{color:var(--muted-l);text-decoration:none;font-size:14px}

@media(max-width:768px){ .nav-links{display:none} .container{padding:0 20px} .about-grid, .info-grid, .reviews-grid, .gallery-grid{grid-template-columns:1fr} }
</style>
</head>
<body>

<nav id="nav">
  <a href="#" class="nav-logo">SATORI</a>
  <ul class="nav-links">
    <li><a href="#about">О нас</a></li>
    <li><a href="#gallery">Атмосфера</a></li>
    <li><a href="#reviews">Отзывы</a></li>
  </ul>
  <a href="javascript:alert('Скоро!')" class="nav-app">Скоро</a>
</nav>

<section class="hero">
  <div class="hero-content">
    <div class="hero-icon"><img src="/Satory.png" alt="S"></div>
    <h1>SATORI</h1>
    <p>Место, где чай становится ритуалом</p>
    <a href="#about" class="hero-btn">Смотреть</a>
  </div>
</section>

<section id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <h2>О чайной</h2>
        <p>SATORI — это не просто чайная, это место, где древние традиции встречаются с современностью.</p>
      </div>
      <div class="about-img"><img src="drink.jpg" alt="About"></div>
    </div>
    <div class="info-grid">
      <div class="info-card"><div class="info-card-icon">📍</div><h3>Адрес</h3><p>ул. Кирова, 26, Адлер</p></div>
      <div class="info-card"><div class="info-card-icon">🕐</div><h3>Часы работы</h3><p>10:00 – 23:00</p></div>
      <div class="info-card"><div class="info-card-icon">📞</div><h3>Контакты</h3><p>+7 (989) 088-74-44</p></div>
    </div>
  </div>
</section>

<section id="gallery" style="background:#000">
  <div class="container">
    <h2 class="section-title">Атмосфера</h2>
    <div class="gallery-grid" id="gallery-grid">
      <!-- Динамическая галерея -->
    </div>
  </div>
</section>

<section id="reviews" class="reviews-section">
  <div class="container">
    <h2 class="section-title">Отзывы</h2>
    <div class="reviews-rating"><div class="reviews-rating-num">4.9</div><div><h3>Яндекс Карты</h3><p>★★★★★</p><p style="font-size:12px;color:var(--muted)">Более 3500 отзывов</p></div></div>
    <div class="reviews-grid">
      <div class="review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-text">Невероятное место! Атмосфера просто волшебная, чай подобран с душой.</p>
        <div class="review-author"><div class="review-avatar">А</div><div><p style="font-size:14px;font-weight:600">Анна К.</p><p style="font-size:12px;color:var(--muted)">Яндекс Карты</p></div></div>
      </div>
      <div class="review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-text">Лучшая чайная в Сочи! Огромный выбор редких чаёв, уютная обстановка.</p>
        <div class="review-author"><div class="review-avatar">М</div><div><p style="font-size:14px;font-weight:600">Михаил Д.</p><p style="font-size:12px;color:var(--muted)">Яндекс Карты</p></div></div>
      </div>
      <div class="review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-text">Были на чайной церемонии — это незабываемо. Мастер очень профессиональный.</p>
        <div class="review-author"><div class="review-avatar">Е</div><div><p style="font-size:14px;font-weight:600">Елена В.</p><p style="font-size:12px;color:var(--muted)">Яндекс Карты</p></div></div>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="container">
    <div class="footer-icon"><img src="/Satory.png" alt="S"></div>
    <div class="footer-logo">SATORI</div>
    <p style="color:var(--muted);font-size:14px">Место, где чай становится ритуалом</p>
    <div class="footer-links">
      <a href="#about">О нас</a> <a href="#gallery">Атмосфера</a> <a href="#reviews">Отзывы</a> 
      <a href="tel:+79890887444">+7 (989) 088-74-44</a> <a href="#">ВКонтакте</a> <a href="javascript:alert('Скоро!')">Приложение</a>
    </div>
    <p style="color:#555;font-size:12px">© 2026 SATORI. Все права защищены.</p>
  </div>
</footer>

<script>
window.addEventListener('scroll', () => { document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 50); });

async function loadGallery() {
  try {
    const res = await fetch('/api/gallery');
    const items = await res.json();
    const grid = document.getElementById('gallery-grid');
    if (!items.length) {
      grid.innerHTML = '<p style="color:gray">Галерея пока пуста</p>';
      return;
    }
    // Берем 6 последних фото
    grid.innerHTML = items.slice(0, 6).map(item => `
      <div class="gallery-item">
        <img src="${item.image_url}" alt="Атмосфера Satori" loading="lazy">
      </div>
    `).join('');
  } catch(e) {
    console.error('Gallery load error:', e);
  }
}
loadGallery();
</script>
</body>
</html>
