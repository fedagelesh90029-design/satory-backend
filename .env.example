# Основные настройки
NODE_ENV=development
PORT=3000
APP_URL=https://satory-tea.ru

# JWT секрет для авторизации
JWT_SECRET=your-super-secret-jwt-key-here

# SMS сервис (для отправки OTP)
SMS_API_KEY=your-sms-api-key
SMS_SENDER=SatoriTea

# iiko API — автоматическая синхронизация меню
IIKO_API_URL=https://api.iiko.ru/api/1
IIKO_API_LOGIN=your-iiko-api-login
IIKO_ORGANIZATION_ID=your-organization-uuid
IIKO_SYNC_CRON=0 0,6,12,18 * * *

# ЮKassa (карта + СБП)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Яндекс.Диск для синхронизации
YANDEX_TOKEN=your-yandex-disk-token

# Push-уведомления
EXPO_ACCESS_TOKEN=your-expo-access-token

# Настройки бонусной системы
BONUS_RATE=0.01  # 1% от суммы покупки
BONUS_MIN_ORDER=500  # Минимальная сумма заказа для начисления бонусов

# Настройки платежей
PAYMENT_TIMEOUT=900  # 15 минут на оплату (в секундах)
MIN_PAYMENT_AMOUNT=100  # Минимальная сумма платежа (в рублях)