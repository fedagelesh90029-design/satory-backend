# Основные настройки
NODE_ENV=development
PORT=3000
APP_URL=https://satory-tea.ru

# JWT секрет для авторизации
JWT_SECRET=your-super-secret-jwt-key-here

# SMS сервис — выбери провайдера: mts / smsc / smsaero / smsru
SMS_PROVIDER=mts

# МТС Exolve (рекомендуется, от 1.2 ₽/SMS)
# Регистрация: https://exolve.ru
MTS_API_KEY=your-mts-exolve-api-key
MTS_SENDER=SatoriTea

# SMSC.ru (от 1.5 ₽/SMS)
# SMS_PROVIDER=smsc
# SMSC_LOGIN=your-smsc-login
# SMSC_PASSWORD=your-smsc-password

# SMS Aero
# SMS_PROVIDER=smsaero
# SMSAERO_EMAIL=your-email
# SMSAERO_API_KEY=your-api-key
# SMSAERO_SIGN=SatoriTea

# SMS.ru
# SMS_PROVIDER=smsru
# SMS_API_KEY=your-sms-ru-api-key

# ВКонтакте (VK Notify) — бесплатно для верифицированных сообществ
# SMS_PROVIDER=vk
# VK_SERVICE_TOKEN=your-vk-service-token

# Telegram Bot — отправка кода в Telegram
# SMS_PROVIDER=telegram
# TG_BOT_TOKEN=your-telegram-bot-token
# TG_CHAT_ID=your-telegram-chat-id

# iiko API — автоматическая синхронизация меню
IIKO_API_URL=https://api.iiko.ru/api/1
IIKO_API_LOGIN=your-iiko-api-login
IIKO_ORGANIZATION_ID=your-organization-uuid
IIKO_SYNC_CRON=0 0,6,12,18 * * *

# ЮKassa (карта + СБП)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Яндекс.Диск для синхронизации
YANDEX_TOKEN=your-yandex-disk-token

# Push-уведомления
EXPO_ACCESS_TOKEN=your-expo-access-token

# Настройки бонусной системы
BONUS_RATE=0.01  # 1% от суммы покупки
BONUS_MIN_ORDER=500  # Минимальная сумма заказа для начисления бонусов

# Настройки платежей
PAYMENT_TIMEOUT=900  # 15 минут на оплату (в секундах)
MIN_PAYMENT_AMOUNT=100  # Минимальная сумма платежа (в рублях)