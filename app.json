{
  "expo": {
    "name": "САТОРИ",
    "slug": "satori-tea-v2",
    "version": "1.3.9",
    "orientation": "portrait",
    "scheme": "satory",
    "userInterfaceStyle": "dark",
    "icon": "./assets/Satory.png",
    "splash": {
      "image": "./assets/Satory.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.satory.tea",
      "icon": "./assets/Satory.png",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.satory.tea",
      "versionCode": 141,
      "icon": "./assets/Satory.png",
      "googleServicesFile": "./google-services.json",
      "navigationBarColor": "#141414",
      "usesCleartextTraffic": true,
      "networkSecurityConfig": "./assets/network_security_config.xml",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Satory.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/Satory.png",
          "color": "#E4B10D",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#0A0A0A"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b71af60e-4389-41ac-8e59-a379cbb78c1d"
      }
    }
  }
}
