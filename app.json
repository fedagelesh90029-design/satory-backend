{
  "expo": {
    "name": "Satori",
    "slug": "satory-tea",
    "owner": "fedoro",
    "version": "1.3.6",
    "orientation": "portrait",
    "scheme": "satory",
    "userInterfaceStyle": "dark",
    "icon": "./assets/Satory.png",
    "splash": {
      "image": "./assets/Satory.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.satory.tea",
      "icon": "./assets/Satory.png"
    },
    "android": {
      "package": "com.satory.tea",
      "versionCode": 137,
      "icon": "./assets/Satory.png",
      "googleServicesFile": "./google-services.json",
      "navigationBarColor": "#141414",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Satory.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/Satory.png",
          "color": "#D4A017",
          "defaultChannel": "default"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#0A0A0A"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6ec0d7cc-9893-4c37-8c33-e9363b02e5ea"
      }
    }
  }
}
